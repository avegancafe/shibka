# Copy to /etc/shibka.env on the server (production) — NEVER commit the real file.
# For local dev, the docker-compose "app" service already sets these; if you run
# Node on your host against the compose DB, export these in your shell instead.

# Neon connection string. Use the POOLED endpoint (host contains "-pooler").
# Any sslmode in the URL is IGNORED (db.js strips it; TLS is governed by PGSSL /
# the ssl option, not the URL). Find it in the Neon console → Connection Details.
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Secret used to sign session cookies. Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# Port the Node app listens on (Caddy proxies to this). Default 3000.
PORT=3000

# Production must be set so cookies are marked Secure (HTTPS-only).
NODE_ENV=production

# TLS handling. Leave UNSET for Neon (full cert verification — the secure default).
#   PGSSL=disable    -> no TLS (local docker-compose Postgres)
#   PGSSL=no-verify  -> TLS without cert verification (self-signed servers)
# PGSSL=disable
