# Production environment for Shibka.
#
# Copy this to a file named `.env` alongside docker-compose.app.yml — i.e. in
# the deploy/ directory of the box's checkout: ~/apps/shibka/deploy/.env.
# The compose file loads it via `env_file`. NEVER commit the real .env (it is
# gitignored). PORT and NODE_ENV are set in the compose file, not here.

# Neon connection string — use the POOLED endpoint (host contains "-pooler").
# Fetch it with:
#   npx neonctl connection-string --project-id red-bread-86298984 \
#     --org-id org-billowing-wildflower-14648462 --pooled
# (TLS uses full certificate verification by default — see server/db.js.)
DATABASE_URL=

# Secret used to sign session cookies. Generate on the box with:
#   openssl rand -hex 32
SESSION_SECRET=
