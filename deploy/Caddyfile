# Caddyfile — Shibka's reverse-proxy site block for shibka.kyleholzinger.dev.
#
# CANONICAL COPY lives in the shared proxy repo, avegancafe_lb, as
# sites/shibka.kyleholzinger.dev.caddy (github.com/avegancafe/avegancafe_lb,
# cloned at ~/apps/lb on the box). This file is the in-repo reference/source;
# keep the two in sync. To apply routing changes: edit it in avegancafe_lb,
# push, then `cd ~/apps/lb && ./deploy.sh` (graceful reload, no cert churn).
#
# Caddy reaches the app by container name over proxy_net; the container does not
# publish ports to the host.

shibka.kyleholzinger.dev {
    # Automatic HTTPS via Let's Encrypt (production ACME). Caddy handles
    # issuance, renewal, and the HTTP->HTTPS redirect.

    header {
        # HSTS belongs at the TLS terminator (Caddy), only sent over HTTPS.
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        # Don't advertise the server software.
        -Server
    }

    # The Node app serves both the static game and /api. Reached by container
    # name over proxy_net; the container does not publish ports to the host.
    reverse_proxy shibka:3000 {
        health_uri /healthz
        health_interval 30s
    }
}
